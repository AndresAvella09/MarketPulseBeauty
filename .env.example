# MarketPulse Beauty — environment template
# Copy to `.env` and fill in real values. `.env` is git-ignored.
#
# Quick start for a new teammate:
#   cp .env.example .env
#   # edit POSTGRES_PASSWORD and the others below
#   docker compose up -d
#   # then follow TEAM_SETUP.md to restore marketpulse_gold.dump

# ── Postgres (gold layer + airflow metadata) ──────────────────────────────
# The streamlit container connects via:
#   PG_CONN=postgresql+psycopg2://postgres:${POSTGRES_PASSWORD}@postgres:5432/marketpulse
POSTGRES_PASSWORD=changeme

# ── MinIO (S3-compatible object store for parquet artefacts) ──────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme

# ── Airflow ───────────────────────────────────────────────────────────────
# Generate a fresh key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=replace-with-fernet-key

# ── JupyterLab access token ───────────────────────────────────────────────
JUPYTER_TOKEN=changeme

# ── External APIs (only needed if you run the ingestion DAGs locally) ────
# Leave blank if you only run the streamlit dashboard against a restored dump.
BAZAARVOICE_PASSKEY=
HF_TOKEN=
