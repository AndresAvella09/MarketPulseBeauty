# ─────────────────────────────
# DATA (CRÍTICO)
# ─────────────────────────────
# Ignorar TODO el directorio data
data/**

# PERMITIR solo metadata de DVC y estructura
!data/**/*.dvc
!data/**/.gitignore
!data/**/.gitkeep

# (Opcional) permitir xml si lo necesitas versionar
!data/raw/xml/*.xml
data/raw/xml/products-sitemap.xml

# ─────────────────────────────
# PARQUET, CSV, JSON pesados
# ─────────────────────────────
*.parquet
*.csv
*.json

# ⚠️ EXCEPCIÓN: metadata útil
!data/**/*.dvc

# ─────────────────────────────
# ENTORNOS
# ─────────────────────────────
venv/
.venv/
env/
ENV/

# ─────────────────────────────
# VARIABLES SENSIBLES
# ─────────────────────────────
.env
.env.*
*.env

# But the template MUST ship so teammates can copy it
!.env.example

# También tu scraper tiene uno aquí:
src/**/.env

# ─────────────────────────────
# PYTHON CACHE
# ─────────────────────────────
**/__pycache__/
*.py[cod]
*.pyd
*.pytest_cache/
.ipynb_checkpoints/

# ─────────────────────────────
# LOGS
# ─────────────────────────────
logs/
*.log

# ─────────────────────────────
# ARCHIVOS SENSIBLES
# ─────────────────────────────
sephora_cookies.json
src/**/sephora_cookies.json

# ─────────────────────────────
# OS / IDE
# ─────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─────────────────────────────
# BUILD
# ─────────────────────────────
build/
dist/
*.egg-info/

# Local parquet data (do not commit)
*.parquet
data/local/
data/bronze/
data/silver/
data/gold/

# ─────────────────────────────
# DOCKER / AIRFLOW
# ─────────────────────────────
airflow/logs/
airflow/dags/__pycache__/

# ─────────────────────────────
# CLAUDE CODE
# ─────────────────────────────
.claude/
mem_log.txt

# ─────────────────────────────
# NOTEBOOKS OUTPUT
# ─────────────────────────────
notebooks/.ipynb_checkpoints/

# ─────────────────────────────
# MISC / TEMP
# ─────────────────────────────
*.docx
*.xlsx
*.png
*.jpg
*.jpeg
image.png
architecture_diagram.html

# ─────────────────────────────
# DASHBOARD DESIGN DRAFTS (local only)
# ─────────────────────────────
dashboard_design_prompt.md
dashboard_business_questions.md

# ─────────────────────────────
# POSTGRES SNAPSHOTS / TEAM DATA HANDOFF
# ─────────────────────────────
*.dump
*.backup
*.sql.gz
*.sql.bz2
*.tar.gz
*.tgz
*.zip
dumps/
backups/
snapshots/
data_snapshots/

# ─────────────────────────────
# FRONTEND — Streamlit dashboard SHIPS in the repo
# (the old per-developer rule was retired when the dashboard became a
# single shared codebase consumed by the streamlit container)
# ─────────────────────────────
# src/dashboard/  ← do NOT ignore; the streamlit service imports it

# ─────────────────────────────
# FRONTEND / UI ASSETS (design references — not required at runtime)
# ─────────────────────────────
assets/
preview/
ui_kits/

# Standalone HTML / design source files (not used by the Streamlit app at
# runtime — Plotly/Streamlit produce their own HTML in-memory)
*.html
*.css
*.scss
*.sass
*.less
*.svg
*.ico
*.webp
*.gif
*.bmp
*.tiff
*.avif

# JS/TS build artifacts (no JS bundle ships with this app)
*.js
*.ts
*.jsx
*.tsx
node_modules/
.next/
.nuxt/
.svelte-kit/
out/
public/
static/
