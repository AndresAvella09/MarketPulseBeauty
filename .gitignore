	# ─────────────────
# Datos y CSV (MarketPulse Specific)
# ─────────────────
# Ignorar todos los datos
data/*

# PERO permitir archivos DVC y estructura
!data/**/*.dvc
!data/**/.gitignore
!data/**/.gitkeep

# ─────────────────
# Entorno virtual
# ─────────────────
venv/
.venv/
env/
ENV/

# ─────────────────
# Variables privadas
# ─────────────────
.env
.env.*
*.env

# ─────────────────
# Python & Cache
# ─────────────────
**/__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pytest_cache/
.ipynb_checkpoints/

# ─────────────────
# Logs & temporales
# ─────────────────
*.log
*.tmp
logs/

# ─────────────────
# Archivos sensibles (scraping)
# ─────────────────
sephora_cookies.json
src/**/sephora_cookies.json

# ─────────────────
# OS & IDE
# ─────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─────────────────
# Python packaging
# ─────────────────
build/
dist/
*.egg-info/

# Local parquet data (do not commit)
*.parquet
data/local/
data/bronze/
data/silver/
data/gold/
# BEGIN LOCAL_PARQUET_DATA
# Local parquet data (do not commit)
*.parquet
data/local/
data/bronze/
data/silver/
data/gold/
# END LOCAL_PARQUET_DATA
