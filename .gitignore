# ─────────────────────────────
# DATA (CRÍTICO)
# ─────────────────────────────
# Ignorar TODO el directorio data
data/**

# PERMITIR solo metadata de DVC y estructura
!data/**/*.dvc
!data/**/.gitignore
!data/**/.gitkeep

# (Opcional) permitir xml si lo necesitas versionar
!data/raw/xml/*.xml
data/raw/xml/products-sitemap.xml

# ─────────────────────────────
# PARQUET, CSV, JSON pesados
# ─────────────────────────────
*.parquet
*.csv
*.json

# ⚠️ EXCEPCIÓN: metadata útil
!data/**/*.dvc

# ─────────────────────────────
# ENTORNOS
# ─────────────────────────────
venv/
.venv/
env/
ENV/

# ─────────────────────────────
# VARIABLES SENSIBLES
# ─────────────────────────────
.env
.env.*
*.env

# También tu scraper tiene uno aquí:
src/**/.env

# ─────────────────────────────
# PYTHON CACHE
# ─────────────────────────────
**/__pycache__/
*.py[cod]
*.pyd
*.pytest_cache/
.ipynb_checkpoints/

# ─────────────────────────────
# LOGS
# ─────────────────────────────
logs/
*.log

# ─────────────────────────────
# ARCHIVOS SENSIBLES
# ─────────────────────────────
sephora_cookies.json
src/**/sephora_cookies.json

# ─────────────────────────────
# OS / IDE
# ─────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─────────────────────────────
# BUILD
# ─────────────────────────────
build/
dist/
*.egg-info/

# Local parquet data (do not commit)
*.parquet
data/local/
data/bronze/
data/silver/
data/gold/

# ─────────────────────────────
# DOCKER / AIRFLOW
# ─────────────────────────────
airflow/logs/
airflow/dags/__pycache__/

# ─────────────────────────────
# CLAUDE CODE
# ─────────────────────────────
.claude/
mem_log.txt

# ─────────────────────────────
# NOTEBOOKS OUTPUT
# ─────────────────────────────
notebooks/.ipynb_checkpoints/

# ─────────────────────────────
# MISC / TEMP
# ─────────────────────────────
*.docx
*.xlsx
*.png
*.jpg
*.jpeg
image.png
architecture_diagram.html

# ─────────────────────────────
# DASHBOARD DESIGN DRAFTS (local only)
# ─────────────────────────────
dashboard_design_prompt.md
dashboard_business_questions.md

# ─────────────────────────────
# POSTGRES SNAPSHOTS / TEAM DATA HANDOFF
# ─────────────────────────────
*.dump
*.backup
*.sql.gz
*.sql.bz2
*.tar.gz
*.tgz
*.zip
dumps/
backups/
snapshots/
data_snapshots/

# ─────────────────────────────
# FRONTEND (per-developer, avoid merge conflicts)
# Each teammate maintains their own dashboard code locally.
# Only app.py at the repo root is shared.
# ─────────────────────────────
src/dashboard/

# ─────────────────────────────
# FRONTEND / UI ASSETS (local only)
# ─────────────────────────────
assets/
preview/
ui_kits/

# HTML files (design previews, prototypes)
*.html

# Web / design source files
*.css
*.scss
*.sass
*.less
*.svg
*.ico
*.webp
*.gif
*.bmp
*.tiff
*.avif

# JS/TS build artifacts and source
*.js
*.ts
*.jsx
*.tsx
node_modules/
.next/
.nuxt/
.svelte-kit/
out/
public/
static/
