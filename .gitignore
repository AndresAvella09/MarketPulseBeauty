# ─────────────────
# Datos y CSV (MarketPulse Specific)
# ─────────────────
# Ignore all data directories content
data/raw/
data/processed/

# Specific data formats
*.csv
*.parquet
*.json
!sephora_cookies.json  # Exception if you want to keep the template (optional)

# Keep the folder structure but ignore the files
!data/**/.gitkeep
logs/*.log

# ─────────────────
# Entorno virtual
# ─────────────────
venv/
.venv/
env/
ENV/

# ─────────────────
# Variables privadas
# ─────────────────
.env
.env.*
*.env

# ─────────────────
# Python & Cache
# ─────────────────
**/__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pytest_cache/
.ipynb_checkpoints/

# ─────────────────
# Archivos sensibles & Scraping
# ─────────────────
sephora_cookies.json
src/**/sephora_cookies.json
*.log
*.tmp

