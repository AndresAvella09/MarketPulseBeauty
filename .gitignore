# ─────────────────────────────
# DATA (CRÍTICO)
# ─────────────────────────────
# Ignorar TODO el directorio data
data/**

# PERMITIR solo metadata de DVC y estructura
!data/**/*.dvc
!data/**/.gitignore
!data/**/.gitkeep

# (Opcional) permitir xml si lo necesitas versionar
!data/raw/xml/*.xml

# ─────────────────────────────
# PARQUET, CSV, JSON pesados
# ─────────────────────────────
*.parquet
*.csv
*.json

# ⚠️ EXCEPCIÓN: metadata útil
!data/**/*.dvc

# ─────────────────────────────
# ENTORNOS
# ─────────────────────────────
venv/
.venv/
env/
ENV/

# ─────────────────────────────
# VARIABLES SENSIBLES
# ─────────────────────────────
.env
.env.*
*.env

# También tu scraper tiene uno aquí:
src/**/.env

# ─────────────────────────────
# PYTHON CACHE
# ─────────────────────────────
**/__pycache__/
*.py[cod]
*.pyd
*.pytest_cache/
.ipynb_checkpoints/

# ─────────────────────────────
# LOGS
# ─────────────────────────────
logs/
*.log

# ─────────────────────────────
# ARCHIVOS SENSIBLES
# ─────────────────────────────
sephora_cookies.json
src/**/sephora_cookies.json

# ─────────────────────────────
# OS / IDE
# ─────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─────────────────────────────
# BUILD
# ─────────────────────────────
build/
dist/
*.egg-info/

# ─────────────────────────────
# DOCKER / AIRFLOW
# ─────────────────────────────
airflow/logs/
airflow/dags/__pycache__/